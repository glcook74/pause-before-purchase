{
  "manifest_version": 3,
  "name": "Dopamine Delay",
  "version": "1.0.0",
  "description": "A pause-before-purchase companion for ADHD brains. Intercepts online checkouts with a brief, voluntary pause — grounded in dopamine reward deficit research.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.supabase.co/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.co.uk/*",
        "*://*.asos.com/*",
        "*://*.ebay.co.uk/*",
        "*://*.argos.co.uk/*",
        "*://*.tesco.com/*",
        "*://*.boots.com/*",
        "*://*.johnlewis.com/*",
        "*://*.currys.co.uk/*",
        "*://*.shein.co.uk/*",
        "*://*.shein.com/*",
        "*://*.klarna.com/*"
      ],
      "js": ["lib/browser-polyfill.js", "lib/storage.js", "lib/alternatives.js", "lib/keys.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["lib/browser-polyfill.js", "lib/storage.js", "lib/alternatives.js", "lib/keys.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle",
      "include_globs": [
        "*checkout*",
        "*basket*",
        "*cart*",
        "*payment*",
        "*order-confirm*",
        "*buy-now*",
        "*order*confirm*",
        "*pay*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
